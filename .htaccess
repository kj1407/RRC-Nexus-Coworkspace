# ====================================================================
#   RRC NEXUS COWORKING SPACE — MASTER PRODUCTION CONFIGURATION (2026)
# ====================================================================

RewriteEngine On
RewriteBase /

# --------------------------------------------------------------------
# A. CLEAN URL ENGINE & INDEX MAPPING
# --------------------------------------------------------------------

# 1. Map the structural /Home endpoint to index.html internally
RewriteRule ^Home$ index.html [L]

# 2. Externally redirect direct requests for /Home.html or /index.html straight to /Home
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/index\.html [NC,OR]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/Home\.html [NC]
RewriteRule ^.*$ https://rrcnexus.com/Home [R=301,L]

# 3. Externally redirect any other legacy incoming .html requests to clean URLs (e.g., /Gallery.html -> /Gallery)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^.]+)\.html [NC]
RewriteRule ^([^.]+)\.html$ https://rrcnexus.com/$1 [R=301,L]

# 4. Internally resolve the clean extensionless URL path back to the actual HTML file
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^/]+)$ $1.html [L]

# --------------------------------------------------------------------
# B. CANONICAL NON-WWW SECURE HTTPS ROUTING
# --------------------------------------------------------------------

# 1. Route www subdomain traffic directly to the clean canonical root apex
RewriteCond %{HTTP_HOST} ^www\.rrcnexus\.com [NC]
RewriteRule ^(.*)$ https://rrcnexus.com/$1 [L,R=301]

# 2. Force SSL layer encryption across all active communication lines
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(www\.)?rrcnexus\.com [NC]
RewriteRule ^(.*)$ https://rrcnexus.com/$1 [L,R=301]

# 3. Route bare root access (https://rrcnexus.com/) cleanly over to /Home
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/\sHTTP [NC]
RewriteRule ^$ https://rrcnexus.com/Home [R=301,L]